rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function validReview(productId, userId) {
      return request.resource.data.keys().hasAll([
          'userId', 'userName', 'userEmail', 'productId', 'orderId',
          'rating', 'comment', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.keys().hasOnly([
          'userId', 'userName', 'userEmail', 'productId', 'orderId',
          'rating', 'comment', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.userId == userId
        && request.resource.data.productId == productId
        && request.resource.data.userName is string
        && request.resource.data.userName.size() > 0
        && request.resource.data.userName.size() <= 120
        && request.resource.data.userEmail is string
        && request.resource.data.orderId is string
        && request.resource.data.orderId.size() > 0
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.comment is string
        && request.resource.data.comment.size() >= 3
        && request.resource.data.comment.size() <= 1000;
    }

    function ownsPurchasedProduct(productId, orderId) {
      let order = get(
        /databases/$(database)/documents/orders/$(orderId)
      ).data;
      return order.userId == request.auth.uid
        && productId in order.productIds;
    }

    function validOrder(orderId, userId) {
      return request.resource.data.keys().hasAll([
          'id', 'userId', 'items', 'productIds', 'total', 'createdAt',
          'status', 'shippingAddress', 'paymentMethod'
        ])
        && request.resource.data.keys().hasOnly([
          'id', 'userId', 'items', 'productIds', 'total', 'createdAt',
          'status', 'shippingAddress', 'paymentMethod'
        ])
        && request.resource.data.id == orderId
        && request.resource.data.userId == userId
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.items.size() <= 100
        && request.resource.data.productIds is list
        && request.resource.data.productIds.size() > 0
        && request.resource.data.productIds.size() <= 100
        && request.resource.data.total is number
        && request.resource.data.total > 0
        && request.resource.data.createdAt is timestamp
        && request.resource.data.status == 'processing'
        && request.resource.data.shippingAddress is string
        && request.resource.data.shippingAddress.size() > 0
        && request.resource.data.shippingAddress.size() <= 500
        && request.resource.data.paymentMethod in ['cod', 'demoCard'];
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }

    match /promos/{promoId} {
      allow read: if true;
      allow write: if false;
    }

    match /orders/{orderId} {
      allow create: if signedIn()
        && validOrder(orderId, request.auth.uid);
      allow read: if signedIn()
        && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if false;

      match /reviews/{userId} {
        allow read: if true;
        allow create: if signedIn()
          && request.auth.uid == userId
          && validReview(productId, userId)
          && ownsPurchasedProduct(
            productId,
            request.resource.data.orderId
          );
        allow update: if signedIn()
          && request.auth.uid == userId
          && validReview(productId, userId)
          && ownsPurchasedProduct(
            productId,
            request.resource.data.orderId
          )
          && request.resource.data.createdAt == resource.data.createdAt;
        allow delete: if signedIn() && request.auth.uid == userId;
      }
    }
  }
}
